# ------------------------------------------------------------------------
alias python='python3'

# ------------------------------------------------------------------------
# stash
# ------------------------------------------------------------------------
alias gsla='git_stash_list_action'

# ------------------------------------------------------------------------
# claude
# ------------------------------------------------------------------------
alias yolo="ENABLE_TOOL_SEARCH=true ENABLE_EXPERIMENTAL_MCP_CLI=false claude --dangerously-skip-permissions"

