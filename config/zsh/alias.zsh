alias ga='git add -A'
alias gc='git commit'
alias gl='fshow'
alias gsl='git stash list'
alias gitmy='open-my-repos'
alias gsync='git switch main && git pull origin main && git fetch origin'
alias gst='git status'

# ------------------------------------------------------------------------
# ls
# ------------------------------------------------------------------------
alias ls='ls --color=auto'
alias la='ls -a'


# ------------------------------------------------------------------------
# tree
# ------------------------------------------------------------------------
alias tree='tree -a -I ".git"'

